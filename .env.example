# Root environment file — shared local infra config.
# Copy to .env and adjust as needed. apps/api and apps/web have their own
# .env.example files for app-specific values.

# ---- Postgres ----
POSTGRES_USER=volttackle
POSTGRES_PASSWORD=volttackle
POSTGRES_DB=volttackle
DATABASE_URL=postgresql://volttackle:volttackle@localhost:15432/volttackle?schema=public

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- Redpanda / Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=volt-tackle
KAFKA_ALERTS_TOPIC=alerts.raw
KAFKA_CONSUMER_GROUP=volt-tackle-alert-processor
