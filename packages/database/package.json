    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/client": "5.20.0",
    "bcryptjs": "2.4.3",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "prisma": "5.20.0",
    "typescript": "5.6.3",
    "tsx": "4.19.2",
    "@types/bcryptjs": "2.4.6"
  }
}
