# Copy to apps/api/.env

# ---- Server ----
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ---- Database ----
DATABASE_URL=postgresql://volttackle:volttackle@localhost:15432/volttackle?schema=public

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- Redpanda / Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=volt-tackle-api
KAFKA_ALERTS_TOPIC=alerts.raw
KAFKA_CONSUMER_GROUP=volt-tackle-alert-processor
# Set to "true" to bypass Kafka entirely and process webhook alerts inline (useful for quick demos).
KAFKA_DISABLED=false

# ---- Auth ----
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=12h

# ---- LLM Providers ----
# Leave blank to use the deterministic mock LLM + embeddings provider.
LLM_PROVIDER=mock
# openai | anthropic | featherless | mock

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Featherless AI (OpenAI-compatible, serves open-weight models).
# Set LLM_PROVIDER=featherless and paste your key to use real AI output.
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

EMBEDDINGS_PROVIDER=mock
# openai | mock  (embeddings stay on mock unless you set OPENAI_API_KEY)

# ---- Enkrypt AI Safety Layer ----
# Leave blank to use the built-in mock safety adapter.
ENKRYPT_API_KEY=
ENKRYPT_BASE_URL=https://api.enkryptai.com
SAFETY_PROVIDER=mock
# enkrypt | mock

# ---- Monitoring provider (Datadog/Prometheus) ----
MONITORING_PROVIDER=mock
DATADOG_API_KEY=
DATADOG_APP_KEY=
PROMETHEUS_URL=

# ---- Deployment metadata provider (GitHub/GitLab) ----
DEPLOYMENT_PROVIDER=mock
GITHUB_TOKEN=
GITHUB_REPO=

# ---- Repo context layer (GitAgent) — OPTIONAL, default off ----
# none      : no repo analysis (identical to pre-GitAgent behavior)
# mock      : deterministic offline repo context (no git, no network)
# local-git : real `git` clone/inspect of the mapped repo (no LLM)
# gitagent  : real @open-gitagent/gitagent library — clones the repo and runs a
#             multi-agent investigation (falls back to local-git on failure)
REPO_CONTEXT_PROVIDER=none
# JSON map of service -> repo URL or local path (used when no runtime repoUrl is
# supplied, e.g. by the "Postmortem a GitHub repo" panel which passes the URL):
#   {"checkout-api":"https://github.com/acme/checkout-api"}
#   {"checkout-api":"C:/path/to/local/checkout-api"}   (local-git can analyze a local checkout)
INCIDENT_REPO_MAP=
# gitagent binary name (used only if you invoke the CLI path directly)
GITAGENT_BIN=gitagent

# --- GitAgent's own LLM (only when REPO_CONTEXT_PROVIDER=gitagent) ---
# Option A (recommended, matches the gitarch convention): Lyzr.
# Set both of these and the model string is built automatically as
#   lyzr:<GITAGENT_LYZR_AGENT_ID>@<LYZR_BASE_URL>
LYZR_API_KEY=
GITAGENT_LYZR_AGENT_ID=
LYZR_BASE_URL=https://agent-prod.studio.lyzr.ai/v4
# Option B: set an explicit model string + key instead of the Lyzr pair above.
# Featherless works too via the @baseUrl syntax, e.g.
#   GITAGENT_MODEL=openai:Qwen/Qwen2.5-7B-Instruct@https://api.featherless.ai/v1
#   GITAGENT_LLM_API_KEY=<your featherless key>
GITAGENT_LLM_API_KEY=
GITAGENT_MODEL=
# Optional alternative base-URL override for gitagent's model (rarely needed;
# prefer the @baseUrl suffix in GITAGENT_MODEL). See docs/adr/0009.
GITAGENT_OPENAI_BASE_URL=

# ==========================================================================
# HOW TO ENABLE THE REAL DEMO PATH (all optional — defaults above run offline)
#   Reasoning LLM : LLM_PROVIDER=featherless + FEATHERLESS_API_KEY=<key>
#   Safety gate   : SAFETY_PROVIDER=enkrypt   + ENKRYPT_API_KEY=<key>
#   Repo analysis : REPO_CONTEXT_PROVIDER=gitagent + GITHUB_TOKEN=<pat>
#                   + LYZR_API_KEY=<key> + GITAGENT_LYZR_AGENT_ID=<agent id>
# Keep real secrets in .env (git-ignored), never in this .env.example file.
# ==========================================================================

# ---- Observability ----
OTEL_SERVICE_NAME=volt-tackle-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_CONSOLE=true
